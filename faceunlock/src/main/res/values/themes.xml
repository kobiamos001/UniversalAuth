<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- העיצוב הראשי בסגנון Material 3 המודרני -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- פלטת צבעים מודרנית (כחול/תכלת הייטק) -->
        <item name="colorPrimary">#0284C7</item>
        <item name="colorSecondary">#0369A1</item>
        <item name="colorError">#D32F2F</item>
        <item name="android:windowActivityTransitions">true</item>
        
        <!-- זה מה שהופך את המתגים אוטומטית לעבים ומודרניים -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <style name="SettingsTheme" parent="AppTheme" />
</resources>
