<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp"
        tools:context=".MainActivity">

        <!-- כפתור הגדרות -->
        <ImageView
            android:id="@+id/btn_open_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#888888"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- כרטיסיית סטטוס -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="48dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#E1F5FE"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@android:drawable/ic_secure"
                    app:tint="#0277BD" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Face Unlock"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#01579B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="System active and secured"
                    android:textSize="14sp"
                    android:textColor="#0277BD" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- כרטיסיית פעולות -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/actions_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="24dp"
            app:layout_constraintTop_toBottomOf="@id/status_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/setup_btn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Set Up Face"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center_vertical|start"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="?attr/colorPrimary"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/auth_btn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Test Authentication"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center_vertical|start"
                    app:icon="@android:drawable/ic_secure"
                    app:iconTint="?attr/colorPrimary"
                    app:iconGravity="textStart" />

                <!-- קו הפרדה - מוחלף לצבע בטוח במקום המשתנה שקרס -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginVertical="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/remove_btn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Remove Face Data"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="#D32F2F"
                    android:gravity="center_vertical|start"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="#D32F2F"
                    app:iconGravity="textStart" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
